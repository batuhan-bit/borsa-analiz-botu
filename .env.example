# =========================================================
#  Borsa Analiz Botu - Ortam Değişkenleri (ÖRNEK)
#  Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
#  .env dosyası ASLA commit edilmez (.gitignore'da).
#  GitHub Actions'ta bunlar "Repository Secrets" olarak eklenir.
# =========================================================

# --- Alpaca (market data API) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Ücretsiz plan için genelde: https://data.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Alpha Vantage (temel veri) ---
ALPHA_VANTAGE_API_KEY=

# --- Finnhub (temel veri çapraz doğrulama — opsiyonel, ÜCRETSİZ) ---
# Alpha Vantage'ın haber duygusuyla bağımsız bir kaynaktan (finnhub.io)
# haber duygu skoru çeker. Yoksa çapraz doğrulama atlanır, yalnızca Alpha
# Vantage kullanılır. Ücretsiz anahtar: https://finnhub.io/register
FINNHUB_API_KEY=

# --- Slack Incoming Webhook ---
SLACK_WEBHOOK_URL=

# --- Google Sheets ---
# Service Account JSON dosyasının yolu (lokal geliştirme için)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# GitHub Actions'ta JSON içeriğini tek bir secret olarak vermek için (opsiyonel)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Loglamanın yapılacağı Google Sheet ID'si
GOOGLE_SHEET_ID=
